# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
# *.jks  <- NO ignorar: el keystore de Gemlish está en credentials/ y es necesario para EAS local
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
# *.pem  <- NO ignorar: el certificado PEM está en credentials/ y es necesario para Play Console

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
# /android is intentionally NOT ignored so the pre-generated gradle.properties
# (with android.minSdkVersion=24) is included in the build checkpoint

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
logs
*.log

# OS
Thumbs.db

# Build files
*.tgz
*.tar.gz
.cache/

# Webdev artifacts (checkpoint zips, migrations, etc.)
.webdev/
